// 将键绑定放在此文件中以覆盖默认值
[
    {
        // 在编辑器中触发内联建议
        "key": "alt+p",
        "command": "editor.action.inlineSuggest.trigger",
        "when": "editorFocus",
    },
    {
        // 打开 Copilot Chat Debug
        "key": "ctrl+shift+alt+d",
        "command": "github.copilot.debug.showChatLogView",
    },
]
